{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lucky WOL Agent",
  "version": "0.1.0",
  "identifier": "com.tyc.lucky-wol-agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lucky WOL Agent",
        "width": 860,
        "height": 540,
        "minWidth": 860,
        "minHeight": 540,
        "maxWidth": 860,
        "maxHeight": 540,
        "center": true,
        "visible": false,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
